# Monorepo-aware build: the build context is the REPO ROOT (see
# docker-compose.yml's `context: .` / `dockerfile: apps/api/Dockerfile`), so
# the pnpm workspace root files are visible and a filtered install only
# fetches this app's dependencies.

# ---- Build stage ----
FROM node:20-bookworm-slim AS build
WORKDIR /repo

RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY apps/api/package.json ./apps/api/package.json
RUN pnpm install --frozen-lockfile --filter @codecampus/api... || pnpm install --filter @codecampus/api...

COPY apps/api ./apps/api
RUN pnpm --filter @codecampus/api build

# ---- Runtime stage ----
FROM node:20-bookworm-slim AS runtime
WORKDIR /repo
ENV NODE_ENV=production
RUN corepack enable

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY apps/api/package.json ./apps/api/package.json
RUN pnpm install --prod --frozen-lockfile --filter @codecampus/api... || pnpm install --prod --filter @codecampus/api...

COPY --from=build /repo/apps/api/dist ./apps/api/dist

WORKDIR /repo/apps/api
EXPOSE 3000
CMD ["node", "dist/main.js"]
