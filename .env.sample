# ---- App ----
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Database (Postgres) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=codecampus
DATABASE_SSL=false
DATABASE_LOGGING=false
# Overrides the discrete vars above if set:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/codecampus

# ---- Redis (BullMQ + cache + throttler + socket adapter) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Auth / JWT (httpOnly cookies) ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=1d
JWT_REFRESH_TTL=7d
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# ---- Piston (code execution sandbox) ----
# Comma-separated list of full execute endpoints for the replica pool
PISTON_URLS=http://localhost:2000/api/v2/execute
PISTON_MAX_INFLIGHT=16
PISTON_CONNECT_TIMEOUT_MS=2000

# ---- Language runtimes / limits ----
PYTHON_VERSION=3.11.0
CPP_VERSION=10.2.0
JAVA_VERSION=15.0.2
JS_VERSION=20.11.1
DEFAULT_RUN_TIMEOUT_MS=3000
DEFAULT_RUN_MEMORY_LIMIT=256000000
DEFAULT_MAX_PROCESS_COUNT=64
DEFAULT_OUTPUT_MAX_BYTES=65536

# ---- Judge queue ----
JUDGE_WORKER_CONCURRENCY=8
JUDGE_QUEUE_RATE_MAX=100
JUDGE_QUEUE_RATE_DURATION_MS=1000

# ---- Rate limiting (per-user) ----
THROTTLE_RUN_PER_MIN=5
THROTTLE_RUN_PER_DAY=50
THROTTLE_SUBMIT_PER_MIN=1
THROTTLE_SUBMIT_PER_DAY=50
THROTTLE_GLOBAL_PER_DAY=1000

# ---- Email (SMTP, demo requests) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@codecampus.dev
DEMO_NOTIFICATION_EMAILS=

# ---- AI module (Phase 2) ----
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8
LLM_MAX_INPUT_TOKENS=12000
LLM_MAX_OUTPUT_TOKENS=8000
LLM_TIMEOUT_MS=120000
LLM_MAX_COST_USD_PER_REQUEST=1.0
AI_FREE_GENERATIONS_PER_MONTH=2
AI_MAX_FILE_BYTES=10485760
AI_RATE_LIMIT_PER_HOUR=5

# ---- Billing (Phase 3) ----
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
BILLING_SUCCESS_URL=http://localhost:5173/billing/success
BILLING_CANCEL_URL=http://localhost:5173/billing/cancel
